# ── AI Providers ──────────────────────────────────────────────────────────────
# Add at least one. Groq and Gemini both have free tiers.
# Groq  → https://console.groq.com        (free)
# Gemini → https://aistudio.google.com    (free)
# OpenAI → https://platform.openai.com/api-keys
# Anthropic → https://console.anthropic.com

GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (local only, no key needed) ────────────────────────────────────────
# Install from https://ollama.com then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Upstash Vector ────────────────────────────────────────────────────────────
# Free serverless vector DB — no Docker needed, works on Vercel.
# 1. Go to https://console.upstash.com
# 2. Create Vector Index
#    - Dimensions: 768  (if using Gemini embeddings — free)
#    - Dimensions: 1536 (if using OpenAI embeddings)
# 3. Paste the REST URL and token below

UPSTASH_VECTOR_REST_URL=https://your-index.upstash.io
UPSTASH_VECTOR_REST_TOKEN=your-token-here
